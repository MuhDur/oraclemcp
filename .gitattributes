# Normalize line endings. This repo is developed on Linux and all committed
# text is already LF; without this, a Windows checkout (autocrlf) rewrites text
# files to CRLF, and the bash e2e/release scripts + golden fixtures then read a
# trailing `\r` — e.g. a golden `serverInfo.version` of "0.9.0\r" fails an
# equality check against the workspace "0.9.0" (bead F-WIN-E2E). Forcing LF on
# checkout keeps every OS byte-identical.
*.sh    text eol=lf
*.bash  text eol=lf
*.py    text eol=lf
*.json  text eol=lf
*.jsonl text eol=lf
*.toml  text eol=lf
*.lock  text eol=lf
*.rs    text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.dict  text eol=lf
*.tsv   text eol=lf

# install.ps1 is checked as a static fixture (installer_e2e asserts it contains
# "    Invoke-OptionalDiscovery\n"); a CRLF checkout breaks the \n-terminated
# needle. Pin LF (PowerShell + PSScriptAnalyzer read LF fine); all .ps1 are
# already LF in-repo so this is checkout-only, no churn.
*.ps1   text eol=lf
