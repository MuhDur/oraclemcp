{
  "$defs": {
    "activeLanesResponse": {
      "$ref": "#/$defs/versionedResponse"
    },
    "auditTailResponse": {
      "$ref": "#/$defs/versionedResponse"
    },
    "changeProposalApplyResponse": {
      "$ref": "#/$defs/versionedResponse"
    },
    "changeProposalDraftResponse": {
      "$ref": "#/$defs/versionedResponse"
    },
    "changeProposalListResponse": {
      "$ref": "#/$defs/versionedResponse"
    },
    "clientCredentialRevokeResponse": {
      "$ref": "#/$defs/versionedResponse"
    },
    "clientCredentialRotateResponse": {
      "$ref": "#/$defs/versionedResponse"
    },
    "clientCredentialsResponse": {
      "$ref": "#/$defs/versionedResponse"
    },
    "configApplyResponse": {
      "$ref": "#/$defs/versionedResponse"
    },
    "configDraftResponse": {
      "$ref": "#/$defs/versionedResponse"
    },
    "configRollbackResponse": {
      "$ref": "#/$defs/versionedResponse"
    },
    "configStatusResponse": {
      "$ref": "#/$defs/versionedResponse"
    },
    "gatedActionResponse": {
      "$ref": "#/$defs/versionedResponse"
    },
    "healthResponse": {
      "$ref": "#/$defs/versionedResponse"
    },
    "metricsResponse": {
      "$ref": "#/$defs/versionedResponse"
    },
    "operatorEvent": {
      "additionalProperties": false,
      "properties": {
        "data": {
          "type": "object"
        },
        "event_id": {
          "minLength": 1,
          "type": "string"
        },
        "event_seq": {
          "minimum": 0,
          "type": "integer"
        },
        "event_type": {
          "minLength": 1,
          "type": "string"
        },
        "lane_id": {
          "minLength": 1,
          "type": "string"
        },
        "protocol_version": {
          "const": "operator.v1"
        },
        "redaction_level": {
          "const": "operator_redacted"
        },
        "schema_version": {
          "const": 1
        },
        "subject_id_hash": {
          "pattern": "^subject-sha256:[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "required": [
        "protocol_version",
        "schema_version",
        "event_seq",
        "event_id",
        "lane_id",
        "subject_id_hash",
        "redaction_level",
        "event_type",
        "data"
      ],
      "type": "object"
    },
    "operatorSchemaBundle": {
      "properties": {
        "$defs": {
          "type": "object"
        },
        "$id": {
          "type": "string"
        },
        "$schema": {
          "type": "string"
        },
        "routes": {
          "items": {
            "$ref": "#/$defs/routeSpec"
          },
          "type": "array"
        }
      },
      "required": [
        "$schema",
        "$id",
        "routes",
        "$defs"
      ],
      "type": "object"
    },
    "routeIndexResponse": {
      "$ref": "#/$defs/versionedResponse"
    },
    "routeSpec": {
      "additionalProperties": false,
      "properties": {
        "mcp_tool": {
          "type": [
            "string",
            "null"
          ]
        },
        "method": {
          "enum": [
            "GET",
            "POST"
          ],
          "type": "string"
        },
        "path": {
          "pattern": "^/operator/v1",
          "type": "string"
        },
        "schema": {
          "minLength": 1,
          "type": "string"
        },
        "sse": {
          "type": "boolean"
        }
      },
      "required": [
        "method",
        "path",
        "schema",
        "sse",
        "mcp_tool"
      ],
      "type": "object"
    },
    "versionedResponse": {
      "additionalProperties": false,
      "properties": {
        "data": {
          "type": "object"
        },
        "protocol_version": {
          "const": "operator.v1"
        },
        "redaction_level": {
          "const": "operator_redacted"
        },
        "route": {
          "pattern": "^/operator/v1",
          "type": "string"
        },
        "schema_version": {
          "const": 1
        }
      },
      "required": [
        "protocol_version",
        "schema_version",
        "route",
        "redaction_level",
        "data"
      ],
      "type": "object"
    },
    "vsessionResponse": {
      "$ref": "#/$defs/versionedResponse"
    }
  },
  "$id": "https://github.com/MuhDur/oraclemcp/schemas/operator.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "routes": [
    {
      "mcp_tool": null,
      "method": "GET",
      "path": "/operator/v1",
      "schema": "routeIndexResponse",
      "sse": false
    },
    {
      "mcp_tool": null,
      "method": "GET",
      "path": "/operator/v1/schema",
      "schema": "operatorSchemaBundle",
      "sse": false
    },
    {
      "mcp_tool": null,
      "method": "GET",
      "path": "/operator/v1/health",
      "schema": "healthResponse",
      "sse": false
    },
    {
      "mcp_tool": null,
      "method": "GET",
      "path": "/operator/v1/metrics",
      "schema": "metricsResponse",
      "sse": false
    },
    {
      "mcp_tool": null,
      "method": "GET",
      "path": "/operator/v1/audit-tail",
      "schema": "auditTailResponse",
      "sse": false
    },
    {
      "mcp_tool": null,
      "method": "GET",
      "path": "/operator/v1/active-lanes",
      "schema": "activeLanesResponse",
      "sse": false
    },
    {
      "mcp_tool": null,
      "method": "GET",
      "path": "/operator/v1/vsession",
      "schema": "vsessionResponse",
      "sse": false
    },
    {
      "mcp_tool": null,
      "method": "GET",
      "path": "/operator/v1/events",
      "schema": "operatorEvent",
      "sse": true
    },
    {
      "mcp_tool": null,
      "method": "GET",
      "path": "/operator/v1/config",
      "schema": "configStatusResponse",
      "sse": false
    },
    {
      "mcp_tool": null,
      "method": "POST",
      "path": "/operator/v1/config/draft",
      "schema": "configDraftResponse",
      "sse": false
    },
    {
      "mcp_tool": null,
      "method": "POST",
      "path": "/operator/v1/config/apply",
      "schema": "configApplyResponse",
      "sse": false
    },
    {
      "mcp_tool": null,
      "method": "POST",
      "path": "/operator/v1/config/rollback",
      "schema": "configRollbackResponse",
      "sse": false
    },
    {
      "mcp_tool": null,
      "method": "GET",
      "path": "/operator/v1/change-proposals",
      "schema": "changeProposalListResponse",
      "sse": false
    },
    {
      "mcp_tool": null,
      "method": "POST",
      "path": "/operator/v1/change-proposals/draft",
      "schema": "changeProposalDraftResponse",
      "sse": false
    },
    {
      "mcp_tool": "proposal-selected apply tool",
      "method": "POST",
      "path": "/operator/v1/change-proposals/apply",
      "schema": "changeProposalApplyResponse",
      "sse": false
    },
    {
      "mcp_tool": null,
      "method": "GET",
      "path": "/operator/v1/client-credentials",
      "schema": "clientCredentialsResponse",
      "sse": false
    },
    {
      "mcp_tool": null,
      "method": "POST",
      "path": "/operator/v1/client-credentials/rotate",
      "schema": "clientCredentialRotateResponse",
      "sse": false
    },
    {
      "mcp_tool": null,
      "method": "POST",
      "path": "/operator/v1/client-credentials/revoke",
      "schema": "clientCredentialRevokeResponse",
      "sse": false
    },
    {
      "mcp_tool": "operator-selected preview tool",
      "method": "POST",
      "path": "/operator/v1/actions/preview",
      "schema": "gatedActionResponse",
      "sse": false
    },
    {
      "mcp_tool": "operator-selected confirmation tool",
      "method": "POST",
      "path": "/operator/v1/actions/confirm",
      "schema": "gatedActionResponse",
      "sse": false
    },
    {
      "mcp_tool": "operator-selected execute tool",
      "method": "POST",
      "path": "/operator/v1/actions/execute",
      "schema": "gatedActionResponse",
      "sse": false
    },
    {
      "mcp_tool": "oracle_set_session_level",
      "method": "POST",
      "path": "/operator/v1/session/set-level",
      "schema": "gatedActionResponse",
      "sse": false
    },
    {
      "mcp_tool": "oracle_switch_profile",
      "method": "POST",
      "path": "/operator/v1/session/switch-profile",
      "schema": "gatedActionResponse",
      "sse": false
    }
  ],
  "title": "oraclemcp operator v1 protocol",
  "type": "object",
  "x-oraclemcp-protocol-version": "operator.v1",
  "x-oraclemcp-schema-version": 1
}
