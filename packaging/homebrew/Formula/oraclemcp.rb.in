class Oraclemcp < Formula
  desc "Engine-free, governed least-privilege Oracle Database MCP server"
  homepage "https://github.com/MuhDur/oraclemcp"
  version "__VERSION__"
  license any_of: ["Apache-2.0", "MIT"]

  depends_on :macos

  on_arm do
    url "https://github.com/MuhDur/oraclemcp/releases/download/v__VERSION__/oraclemcp-aarch64-apple-darwin.tar.gz"
    sha256 "__SHA256_DARWIN_ARM64__"
  end

  on_intel do
    url "https://github.com/MuhDur/oraclemcp/releases/download/v__VERSION__/oraclemcp-x86_64-apple-darwin.tar.gz"
    sha256 "__SHA256_DARWIN_X64__"
  end

  def install
    bin.install "oraclemcp"
    bin.install "om"
  end

  test do
    assert_match version.to_s, shell_output("#{bin}/oraclemcp --version")
    assert_match "oraclemcp", shell_output("#{bin}/om --help")
  end
end
