    {
      "name": "oracle_explain_plan",
      "title": "Oracle Explain Plan",
      "tier": "foundation_live_db",
      "summary": "Explicit diagnostic-write EXPLAIN PLAN for a vetted SELECT; writes PLAN_TABLE, requires READ_WRITE plus allow_plan_table_write, and is disabled on read-only standby.",
      "input_schema": {
        "additionalProperties": false,
        "properties": {
          "allow_plan_table_write": {
            "description": "Default false. Must be true, with the active session at READ_WRITE, before EXPLAIN PLAN may write PLAN_TABLE on a primary database.",
            "type": "boolean"
          },
          "read_only_standby": {
            "description": "If true, refuse even when allow_plan_table_write is true because EXPLAIN PLAN writes PLAN_TABLE. Defaults false.",
            "type": "boolean"
          },
          "sql": {
            "description": "A read-only SELECT to explain.",
            "type": "string"
          }
        },
        "required": [
          "sql"
        ],
        "type": "object"
      },
      "output_schema": {
        "additionalProperties": false,
        "properties": {
          "cost_estimate": {
            "additionalProperties": false,
            "description": "Additive, observational optimizer estimates for the plan just written, scoped to the same plan DBMS_XPLAN.DISPLAY shows. Present only when PLAN_TABLE exposes the cost columns. These are RELATIVE optimizer estimates for ranking plans, not wall-clock time and not a guarantee; cost/cardinality/bytes may be null (no statistics or RULE mode).",
            "properties": {
              "note": {
                "description": "Reminder that the figures are relative optimizer estimates, not measured runtime.",
                "type": "string"
              },
              "rows": {
                "description": "Per plan-line estimates, ordered by PLAN_TABLE.ID.",
                "items": {
                  "additionalProperties": false,
                  "properties": {
                    "bytes": {
                      "description": "Estimated bytes for this line, or null.",
                      "type": [
                        "integer",
                        "null"
                      ]
                    },
                    "cardinality": {
                      "description": "Estimated rows for this line, or null.",
                      "type": [
                        "integer",
                        "null"
                      ]
                    },
                    "cost": {
                      "description": "Relative optimizer cost for this line, or null.",
                      "type": [
                        "integer",
                        "null"
                      ]
                    },
                    "id": {
                      "description": "PLAN_TABLE.ID (0 is the plan root).",
                      "type": "integer"
                    }
                  },
                  "required": [
                    "id",
                    "cost",
                    "cardinality",
                    "bytes"
                  ],
                  "type": "object"
                },
                "type": "array"
              },
              "summary": {
                "additionalProperties": false,
                "description": "The plan root (id=0) totals for the whole plan.",
                "properties": {
                  "total_bytes": {
                    "type": [
                      "integer",
                      "null"
                    ]
                  },
                  "total_cardinality": {
                    "type": [
                      "integer",
                      "null"
                    ]
                  },
                  "total_cost": {
                    "type": [
                      "integer",
                      "null"
                    ]
                  }
                },
                "required": [
                  "total_cost",
                  "total_cardinality",
                  "total_bytes"
                ],
                "type": "object"
              }
            },
            "required": [
              "rows",
              "summary",
              "note"
            ],
            "type": "object"
          },
          "cost_estimate_unavailable": {
            "description": "Present instead of cost_estimate when the PLAN_TABLE cost read could not be produced (e.g. an ancient/RULE-mode database missing a cost column); explains why, and the EXPLAIN plan itself is still returned.",
            "type": "string"
          },
          "diagnostic_write": {
            "additionalProperties": false,
            "properties": {
              "explicitly_allowed": {
                "type": "boolean"
              },
              "required_level": {
                "enum": [
                  "READ_WRITE"
                ],
                "type": "string"
              },
              "statement": {
                "enum": [
                  "EXPLAIN PLAN"
                ],
                "type": "string"
              },
              "writes": {
                "enum": [
                  "PLAN_TABLE"
                ],
                "type": "string"
              }
            },
            "required": [
              "statement",
              "writes",
              "required_level",
              "explicitly_allowed"
            ],
            "type": "object"
          },
          "plan": {
            "description": "Rows returned by DBMS_XPLAN.DISPLAY, usually keyed by PLAN_TABLE_OUTPUT.",
            "items": {
              "additionalProperties": {
                "description": "Serialized Oracle cell value. Oracle NUMBER values are strings by default for lossless precision; JSON numbers are used only for binary float/double or numbers_as_float=true.",
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "number"
                  },
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "null"
                  },
                  {
                    "additionalProperties": true,
                    "type": "object"
                  },
                  {
                    "items": {},
                    "type": "array"
                  }
                ]
              },
              "type": "object"
            },
            "type": "array"
          }
        },
        "required": [
          "plan",
          "diagnostic_write"
        ],
        "type": "object"
      },
      "destructive": true,
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": true,
        "idempotentHint": false,
        "openWorldHint": false
      }
    },
    {
      "name": "oracle_top_queries",
      "title": "Oracle Top Queries",
      "tier": "foundation_live_db",
      "summary": "Read-only top-SQL ranked by elapsed/CPU/buffer-gets/disk-reads over the free live cursor cache (V$SQLSTATS). Opt into historical AWR only when a Diagnostics Pack is licensed, else Statspack, else a structured-unavailable error — never invokes a paid pack unlicensed.",
      "input_schema": {
        "additionalProperties": false,
        "properties": {
          "historical": {
            "description": "If true, use historical AWR (requires a licensed Diagnostics Pack) or Statspack instead of the live cursor cache. Defaults false (the free live source).",
            "type": "boolean"
          },
          "metric": {
            "description": "Ranking metric. Defaults to elapsed.",
            "enum": [
              "elapsed",
              "cpu",
              "buffer_gets",
              "disk_reads"
            ],
            "type": "string"
          },
          "min_pct_of_total": {
            "description": "Live source only: keep only statements consuming at least this percent of the total selected metric (e.g. 5 for the 5%-of-total view).",
            "maximum": 100,
            "minimum": 1,
            "type": "integer"
          },
          "timeout_seconds": {
            "description": "Temporary Oracle per-round-trip call timeout for this tool call. Overrides the profile default only for this call.",
            "maximum": 3600,
            "minimum": 1,
            "type": "integer"
          },
          "top_n": {
            "description": "How many statements to return (1-100, default 20).",
            "maximum": 100,
            "minimum": 1,
            "type": "integer"
          }
        },
        "required": [],
        "type": "object"
      },
      "destructive": false,
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
