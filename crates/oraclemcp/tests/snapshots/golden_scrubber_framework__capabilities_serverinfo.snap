    {
      "name": "execute_approved",
      "title": "Execute Approved",
      "tier": "foundation_live_db",
      "summary": "Compatibility alias for executing a statement previously previewed with preview_sql; token-only calls work for five minutes in the same server process and DML rolls back unless commit=true is explicit, except that non-transactional effects such as sequence NEXTVAL persist after rollback.",
      "input_schema": {
        "additionalProperties": false,
        "properties": {
          "capture_dbms_output": {
            "description": "Default false. When true, returns bounded DBMS_OUTPUT lines. Caller PL/SQL must use literal/bind-only SYS.DBMS_OUTPUT.PUT_LINE statements.",
            "type": "boolean"
          },
          "commit": {
            "description": "Default false rolls back transactional DML, but non-transactional effects such as sequence NEXTVAL persist and still require the preview grant. Set true only when the grant represents deliberate commit intent; DDL/Admin statements require true.",
            "type": "boolean"
          },
          "confirm": {
            "description": "Alias for token.",
            "type": "string"
          },
          "confirmation_token": {
            "description": "Alias for token.",
            "type": "string"
          },
          "dbms_output": {
            "description": "Alias for capture_dbms_output.",
            "type": "boolean"
          },
          "dbms_output_max_chars": {
            "description": "Maximum DBMS_OUTPUT characters to return when capture_dbms_output=true (default 200000).",
            "maximum": 1000000,
            "minimum": 1,
            "type": "integer"
          },
          "dbms_output_max_lines": {
            "description": "Maximum DBMS_OUTPUT lines to return when capture_dbms_output=true (default 200).",
            "maximum": 5000,
            "minimum": 1,
            "type": "integer"
          },
          "max_dbms_output_chars": {
            "description": "Alias for dbms_output_max_chars.",
            "maximum": 1000000,
            "minimum": 1,
            "type": "integer"
          },
          "max_dbms_output_lines": {
            "description": "Alias for dbms_output_max_lines.",
            "maximum": 5000,
            "minimum": 1,
            "type": "integer"
          },
          "save_output": {
            "description": "Unsupported in the generic core. Use capture_dbms_output=true and read dbms_output.lines instead.",
            "type": "string"
          },
          "sql": {
            "description": "Optional SQL statement. If omitted, the token must still be cached from preview_sql in this server process.",
            "type": "string"
          },
          "timeout_seconds": {
            "description": "Temporary Oracle per-round-trip call timeout for this tool call. Overrides the profile default only for this call.",
            "maximum": 3600,
            "minimum": 1,
            "type": "integer"
          },
          "token": {
            "description": "Confirmation token from preview_sql.execute_confirmation.confirm.",
            "type": "string"
          }
        },
        "required": [],
        "type": "object"
      },
      "destructive": true,
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": true,
        "idempotentHint": false,
        "openWorldHint": false
      }
    },
