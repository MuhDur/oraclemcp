    {
      "name": "oracle_query",
      "title": "Oracle Query",
      "tier": "foundation_live_db",
      "summary": "Run a read-only SELECT with positional binds; paginated and row/byte capped.",
      "input_schema": {
        "additionalProperties": false,
        "properties": {
          "as_of": {
            "description": "Flashback / AS-OF read: run this SELECT against a PAST committed snapshot. Pass a NORMAL SELECT (never hand-written AS OF SQL); the base query is proven read-only first, then bounded in a DBMS_FLASHBACK window (the scn/timestamp is bound, never interpolated). Set exactly one of scn or timestamp. Requires the Oracle FLASHBACK privilege (a missing grant surfaces as ORA-01031).",
            "properties": {
              "scn": {
                "description": "System change number to read as of (the deterministic form).",
                "minimum": 1,
                "type": "integer"
              },
              "timestamp": {
                "description": "Wall-clock time to read as of, \"YYYY-MM-DD HH24:MI:SS\" (a T date/time separator is also accepted). Oracle resolves it to the nearest SCN (~3s granularity).",
                "type": "string"
              }
            },
            "type": "object"
          },
          "binds": {
            "description": "Positional bind values (string | number | bool | null) for :1, :2 …",
            "items": {},
            "type": "array"
          },
          "cursor": {
            "description": "Opaque pagination cursor from a prior truncated page (incremental fetch). Resuming with it yields the next page byte-identically.",
            "type": "string"
          },
          "deep_decode": {
            "description": "Opt into larger capped ARRAY/JSON/VECTOR structured decode limits. Default false keeps safe caps.",
            "type": "boolean"
          },
          "limit": {
            "description": "Alias for max_rows for compatibility with older clients. Prefer max_rows.",
            "maximum": 5000,
            "minimum": 1,
            "type": "integer"
          },
          "max_blob_bytes": {
            "description": "Maximum BLOB bytes to inline per cell as base64 (default 1048576).",
            "maximum": 5242880,
            "minimum": 1,
            "type": "integer"
          },
          "max_col_width": {
            "description": "Compatibility text cap for ordinary text/raw columns. Truncated values are returned as { value, truncated, char_length }.",
            "maximum": 1000000,
            "minimum": 1,
            "type": "integer"
          },
          "max_lob_chars": {
            "description": "Maximum CLOB characters to inline per cell (default 32768).",
            "maximum": 1000000,
            "minimum": 1,
            "type": "integer"
          },
          "max_result_bytes": {
            "description": "Maximum serialized JSON bytes in this page (default 10485760, hard cap 26214400).",
            "maximum": 26214400,
            "minimum": 1,
            "type": "integer"
          },
          "max_rows": {
            "description": "Maximum rows in this page / streamed chunk (default 200, hard cap 5000).",
            "maximum": 5000,
            "minimum": 1,
            "type": "integer"
          },
          "max_structured_bytes": {
            "description": "Maximum compact JSON bytes decoded from one structured node. Values above the safe default require deep_decode=true.",
            "maximum": 5242880,
            "minimum": 1,
            "type": "integer"
          },
          "max_structured_cells": {
            "description": "Maximum structured value nodes decoded from one structured cell. Values above the safe default require deep_decode=true.",
            "maximum": 100000,
            "minimum": 1,
            "type": "integer"
          },
          "max_structured_depth": {
            "description": "Maximum ARRAY/JSON recursion depth decoded inside one structured cell. Values above the safe default require deep_decode=true.",
            "maximum": 32,
            "minimum": 1,
            "type": "integer"
          },
          "max_structured_rows": {
            "description": "Maximum direct entries decoded from one structured ARRAY/JSON node. Values above the safe default require deep_decode=true.",
            "maximum": 10000,
            "minimum": 1,
            "type": "integer"
          },
          "numbers_as_float": {
            "description": "Emit numeric values as JSON numbers where possible. Default false preserves Oracle NUMBER losslessly as strings.",
            "type": "boolean"
          },
          "sql": {
            "description": "A single read-only SELECT. Use :1, :2 … for binds.",
            "type": "string"
          },
          "streaming": {
            "description": "Deliver the result incrementally instead of one inline page. Over HTTP/SSE, scalar/self-contained rowsets emit one `event: row` frame per row; LOB, BFILE, and REF CURSOR values fall back to ordered cursor `event: chunk` frames. Mutually exclusive with export and as_of. Never affects the read-only classifier.",
            "type": "boolean"
          },
          "timeout_seconds": {
            "description": "Temporary Oracle per-round-trip call timeout for this tool call. Overrides the profile default only for this call.",
            "maximum": 3600,
            "minimum": 1,
            "type": "integer"
          }
        },
        "required": [
          "sql"
        ],
        "type": "object"
      },
      "output_schema": {
        "additionalProperties": true,
        "properties": {
          "columns": {
            "description": "Column names in select-list order.",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "export": {
            "additionalProperties": true,
            "description": "Present when export=true: metadata for the materialized oracle-export://{id} resource.",
            "type": "object"
          },
          "inlined": {
            "description": "False when the result was materialized as an export resource (export=true) rather than inlined.",
            "type": "boolean"
          },
          "next_cursor": {
            "type": [
              "string",
              "null"
            ]
          },
          "next_step": {
            "type": "string"
          },
          "resource_link": {
            "additionalProperties": true,
            "description": "Present when export=true: an MCP resource_link to the export, to fetch via resources/read.",
            "type": "object"
          },
          "row_count": {
            "minimum": 0,
            "type": "integer"
          },
          "rows": {
            "description": "Serialized rows keyed by column name. NUMBER cells are strings unless numbers_as_float=true.",
            "items": {
              "additionalProperties": {
                "description": "Serialized Oracle cell value. Oracle NUMBER values are strings by default for lossless precision; JSON numbers are used only for binary float/double or numbers_as_float=true.",
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "number"
                  },
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "null"
                  },
                  {
                    "additionalProperties": true,
                    "type": "object"
                  },
                  {
                    "items": {},
                    "type": "array"
                  }
                ]
              },
              "type": "object"
            },
            "type": "array"
          },
          "total_bytes": {
            "minimum": 0,
            "type": "integer"
          },
          "truncated": {
            "type": "boolean"
          }
        },
        "required": [
          "columns",
          "row_count"
        ],
        "type": "object"
      },
      "destructive": false,
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
