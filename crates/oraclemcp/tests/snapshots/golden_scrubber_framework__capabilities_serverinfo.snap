    {
      "name": "oracle_set_session_level",
      "title": "Oracle Set Session Level",
      "tier": "foundation_static",
      "summary": "Preview or apply a temporary session operating-level elevation within the active profile ceiling, or drop back to READ_ONLY.",
      "input_schema": {
        "additionalProperties": false,
        "properties": {
          "action": {
            "description": "Optional action: preview, apply, drop, or status. Omit for preview/apply based on execute.",
            "type": "string"
          },
          "confirm": {
            "description": "Confirmation token returned by preview. Required when execute=true raises the level.",
            "type": "string"
          },
          "confirmation_token": {
            "description": "Alias for confirm.",
            "type": "string"
          },
          "execute": {
            "description": "Default false previews the level change and returns a confirmation token. Set true with confirm to apply elevation.",
            "type": "boolean"
          },
          "level": {
            "description": "Target level: READ_WRITE, DDL, or ADMIN. READ_ONLY drops any active elevation.",
            "type": "string"
          },
          "target_level": {
            "description": "Alias for level.",
            "type": "string"
          },
          "token": {
            "description": "Alias for confirm.",
            "type": "string"
          },
          "ttl_seconds": {
            "description": "Temporary elevation window in seconds (default 900, hard cap 3600).",
            "maximum": 3600,
            "minimum": 1,
            "type": "integer"
          }
        },
        "required": [],
        "type": "object"
      },
      "destructive": true,
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": true,
        "idempotentHint": false,
        "openWorldHint": false
      }
